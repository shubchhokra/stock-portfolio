# ── Backend (Railway) ─────────────────────────────────────────
# From: Supabase Dashboard > Project Settings > API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Port (Railway sets this automatically, leave as-is locally)
PORT=3001

# ── Frontend (Vercel) ─────────────────────────────────────────
# Same SUPABASE_URL as above, but use the ANON key (safe for browser)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Your Railway backend URL (set this in Vercel env vars after deploying backend)
# Locally, point to your dev server
VITE_API_URL=http://localhost:3001
